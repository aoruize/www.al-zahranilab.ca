---
layout: base.njk
navKey: home
pageTitle: "Al-Zahrani Lab"
pageDescription: "Functional Genomics Research Lab at The University of Toronto — Donnelly Centre for Cellular and Biomolecular Research"
permalink: /index.html
---

<!-- Hero -->
  <section class="hero hero--tall">
    <div class="hero-bg">
      <img src="/images/donnelly-centre.jpg" alt="Donnelly Centre for Cellular and Biomolecular Research and CN Tower">
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-title">Functional Genomics Research Lab</h1>
      <p class="hero-description">At The University of Toronto &mdash; Donnelly Centre for Cellular and Biomolecular Research</p>
    </div>
  </section>

  <!-- Our Science -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Research Focus</span>
        <h2 class="section-title">Our Science</h2>
        <p class="section-subtitle">
          We develop and apply high-throughput <em>in vivo</em> functional genomics tools to study how large-scale chromosomal alterations drive tumourigenesis and can be leveraged as a therapeutic vulnerability in cancer.
        </p>
      </div>

      <div class="science-pillars">
        {%- for item in collections.research %}
        <div class="pillar-card">
          <img class="pillar-img" src="{{ item.data.pillarImage }}" alt="{{ item.data.pillarImageAlt }}">
          <div class="pillar-body">
            <h3 class="pillar-title">{{ item.data.pillarTitle }}</h3>
            <p class="pillar-text">{{ item.data.pillarText | safe }}</p>
          </div>
        </div>
        {%- endfor %}
      </div>
    </div>
  </section>

  <!-- Recent Publications -->
  <section class="section">
    <div class="container">
      <div class="section-header-row">
        <div class="section-header">
          <span class="section-label">Selected Work</span>
          <h2 class="section-title">Recent Publications</h2>
        </div>
        <a href="/publications/" class="view-all-link">View all publications &rarr;</a>
      </div>

      <div class="pub-list">
        {%- for pub in collections.publications | limit(4) %}
        <div class="pub-card">
          <div class="pub-meta">
            <span class="pub-journal">{{ pub.data.journal | safe }}</span>
            <span class="pub-year">{{ pub.data.year }}</span>
          </div>
          <h3 class="pub-title">{{ pub.data.title | safe }}</h3>
          <p class="pub-authors">{{ pub.data.authors | safe }}</p>
          {%- if pub.data.url %}
          <a href="{{ pub.data.url }}" target="_blank" rel="noopener" class="pub-link">Read <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg></a>
          {%- endif %}
        </div>
        {%- endfor %}
      </div>
    </div>
  </section>
